# Copiar a .env.local y ajustar. No commitear .env.local (secretos).

# --- Base: PostgreSQL (en Docker Compose suele ser el servicio "db") ---
DATABASE_URL=postgresql://postgres:postgres@db:5432/ayudas

# URL que usa el contenedor "scheduler" para llamar al job (nombre del servicio + puerto interno)
APP_INTERNAL_URL=http://app:3000

# Zona horaria del cron en el scheduler (ej. Europe/Madrid)
TZ=Europe/Madrid

# --- BDNS ---
BDNS_SEARCH_ENDPOINT=
BDNS_BASE_URL=https://www.pap.hacienda.gob.es/bdnstrans/api
BDNS_TIMEOUT_MS=12000
BDNS_RETRIES=2
# Opcional: >0 activa caché en memoria de búsquedas (segundos, máx. 3600)
# BDNS_SEARCH_CACHE_TTL_SECONDS=0

# --- Job de alertas ---
ALERTS_RUN_SECRET=
ALERTS_AUTORUN_CRON=0 9 * * *
# Si true/1/yes: solo se procesan perfiles cuyo schedule_cron coincide con este minuto (TZ).
# Entonces suele hacer falta llamar al job cada minuto, p. ej. ALERTS_AUTORUN_CRON=* * * * *
# ALERTS_RESPECT_PROFILE_CRON=true
ALERTS_DIGEST_PERIOD=diario
ALERTS_CHANNEL_TIMEOUT_MS=15000
ALERTS_CHANNEL_RETRIES=2
ALERTS_CHANNEL_RETRY_DELAY_MS=1000

# --- Email (SMTP) ---
ALERT_RECIPIENTS=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
